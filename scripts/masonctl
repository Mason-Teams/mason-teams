# masonctl - MASON container management tool
# Usage: masonctl <command> [options]

set -e

CONTAINER_NAME="${MASON_CONTAINER_NAME:-mason}"
IMAGE_NAME="${MASON_IMAGE_NAME:-masonteams/mason-teams:stable}"
DATA_VOLUME="${MASON_DATA_VOLUME:-mason-data}"
MASON_DIR="${MASON_DIR:-$HOME/.mason}"

# Ports
PORT_WEB="${MASON_PORT_WEB:-8080}"
PORT_MM="${MASON_PORT_MM:-8065}"
PORT_FORGEJO="${MASON_PORT_FORGEJO:-3000}"

# Resources
MASON_MEMORY="${MASON_MEMORY:-16g}"
MASON_CPUS="${MASON_CPUS:-8}"
MASON_SHM_SIZE="${MASON_SHM_SIZE:-2g}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

print_status() {
    echo -e "${GREEN}[mason]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[mason]${NC} $1"
}

print_error() {
    echo -e "${RED}[mason]${NC} $1" >&2
}

# Confirmation prompt for destructive actions
# Usage: confirm_action "description" || return 0
# Skipped when --yes or -y flag is set
SKIP_CONFIRM=false
confirm_action() {
    if [ "$SKIP_CONFIRM" = true ]; then
        return 0
    fi
    echo -e "${YELLOW}Warning:${NC} $1"
    printf "Continue? [y/N] "
    read -r response
    case "$response" in
        [yY]|[yY][eE][sS]) return 0 ;;
        *) print_status "Cancelled."; return 1 ;;
    esac
}

# Check if Docker is available
check_docker() {
    if ! command -v docker &> /dev/null; then
        print_error "Docker is not installed or not in PATH"
        exit 1
    fi
    if ! docker info &> /dev/null; then
        print_error "Docker daemon is not running"
        exit 1
    fi
}

# Check if container exists
container_exists() {
    docker container inspect "$CONTAINER_NAME" &> /dev/null
}

# Check if container is running
container_running() {
    [ "$(docker container inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)" = "true" ]
}


# Initialize security: generate token and TLS certificates on first run
init_security() {
    # Create MASON_DIR if needed
    if [ ! -d "$MASON_DIR" ]; then
        print_status "Creating $MASON_DIR..."
        mkdir -p "$MASON_DIR"
    fi

    # Generate API token if it doesn't exist
    if [ ! -f "$MASON_DIR/token" ]; then
        print_status "Generating API token..."
        openssl rand -hex 16 > "$MASON_DIR/token"
        chmod 0600 "$MASON_DIR/token"
    fi

    # Generate self-signed TLS certificate if it doesn't exist
    if [ ! -d "$MASON_DIR/tls" ]; then
        mkdir -p "$MASON_DIR/tls"
    fi

    if [ ! -f "$MASON_DIR/tls/mason.crt" ] || [ ! -f "$MASON_DIR/tls/mason.key" ]; then
        print_status "Generating self-signed TLS certificate..."
        openssl req -x509 -newkey rsa:2048 -keyout "$MASON_DIR/tls/mason.key" \
            -out "$MASON_DIR/tls/mason.crt" -days 365 -nodes \
            -subj "/CN=MASON Local/O=MASON" \
            -addext "subjectAltName=DNS:localhost,IP:127.0.0.1" 2>/dev/null
        chmod 0600 "$MASON_DIR/tls/mason.key"
        chmod 0644 "$MASON_DIR/tls/mason.crt"
    fi
}

# Print the current API token
cmd_token() {
    local token_path="${MASON_DIR}/token"
    if [ ! -f "$token_path" ]; then
        print_error "No token found. Run 'masonctl start' to generate one."
        exit 1
    fi
    cat "$token_path"
}

# Open browser to login page with helpful guidance
cmd_login() {
    local token_path="${MASON_DIR}/token"
    local login_url="https://localhost:${PORT_WEB}/login"

    echo ""
    echo -e "  ${GREEN}MASON Login${NC}"
    echo -e "  ──────────────────────────────────────────"
    echo ""

    # Check if token exists
    if [ ! -f "$token_path" ]; then
        print_error "No token found."
        echo ""
        echo "  It looks like MASON hasn't been started yet."
        echo "  Run 'masonctl start' first, then try 'masonctl login' again."
        echo ""
        exit 1
    fi

    # Check if container is running
    check_docker
    if ! container_running; then
        print_warning "The MASON container isn't running."
        echo ""
        echo "  Start it first with:"
        echo -e "    ${GREEN}masonctl start${NC}"
        echo ""
        echo "  Then try 'masonctl login' again."
        echo ""
        exit 1
    fi

    local token
    token=$(cat "$token_path")

    echo "  Your browser session has expired or needs to be refreshed."
    echo "  This is normal — it happens when cookies expire or you"
    echo "  switch browsers."
    echo ""
    echo "  Here's what to do:"
    echo ""
    echo -e "  ${GREEN}1.${NC} A browser window will open to the MASON login page."
    echo -e "  ${GREEN}2.${NC} Copy the token below and paste it into the login form."
    echo -e "  ${GREEN}3.${NC} Click 'Log In' and you're back in."
    echo ""
    echo -e "  Your token:"
    echo ""
    echo -e "    ${YELLOW}${token}${NC}"
    echo ""
    echo -e "  ──────────────────────────────────────────"
    echo ""
    echo -e "  ${GREEN}Tip:${NC} Your token is stored at ~/.mason/token"
    echo "  You can also run 'masonctl token' to print it anytime."
    echo ""

    # Open browser (macOS: open, Linux: xdg-open)
    if command -v open &> /dev/null; then
        open "$login_url" 2>/dev/null
        print_status "Opening $login_url in your browser..."
    elif command -v xdg-open &> /dev/null; then
        xdg-open "$login_url" 2>/dev/null
        print_status "Opening $login_url in your browser..."
    else
        echo "  Open this URL in your browser:"
        echo -e "    ${GREEN}${login_url}${NC}"
    fi
    echo ""
}

# Start the container
cmd_start() {
    check_docker
    init_security

    if container_running; then
        print_warning "Container '$CONTAINER_NAME' is already running"
        return 0
    fi

    if container_exists; then
        print_status "Starting existing container '$CONTAINER_NAME'..."
        docker start "$CONTAINER_NAME"
    else
        print_status "Creating and starting container '$CONTAINER_NAME'..."
        docker run -d \
            --name "$CONTAINER_NAME" \
            --memory "$MASON_MEMORY" \
            --cpus "$MASON_CPUS" \
            --shm-size "$MASON_SHM_SIZE" \
            -p "${PORT_WEB}:8080" \
            -p "${PORT_MM}:8065" \
            -p "${PORT_FORGEJO}:3000" \
            -v "${DATA_VOLUME}:/data" \
            -v "${MASON_DIR}:/data/credentials/mason-security:ro" \
            "$IMAGE_NAME"
    fi

    # Wait for web server to be ready (container handles service health checks)
    print_status "Waiting for container to be ready..."
    for i in $(seq 1 60); do
        # Use /health endpoint — works on both fresh start (200/503) and restart (200/503)
        # /setup returns 302 after wizard completion, which would never match 200
        http_code=$(curl -sk -o /dev/null -w '%{http_code}' "https://localhost:${PORT_WEB}/health" 2>/dev/null || \
                    curl -s -o /dev/null -w '%{http_code}' "http://localhost:${PORT_WEB}/health" 2>/dev/null || true)
        if [ "$http_code" = "200" ] || [ "$http_code" = "503" ]; then
            echo ""
            echo -e "  ${GREEN}MASON is ready!${NC}"
            echo ""
            echo "  Open your browser to get started:"
            echo ""
            echo -e "    → ${GREEN}https://localhost:${PORT_WEB}${NC}"
            echo ""
            echo "  The setup wizard will walk you through everything."
            echo ""
            echo -e "  ${YELLOW}Note:${NC} MASON uses a self-signed TLS certificate."
            echo "  Your browser will show a security warning — this is normal."
            echo "  Click 'Advanced' → 'Proceed' (or 'Accept the Risk') to continue."
            echo ""
            echo "  To remove the warning permanently, you can add MASON's"
            echo "  certificate to your system trust store:"
            echo ""
            echo -e "    ${GREEN}masonctl trust-cert${NC}"
            echo ""
            echo "  Links:"
            echo "    Getting Started: https://localhost:${PORT_WEB}/guide"
            echo "    Documentation:   https://localhost:${PORT_WEB}/docs/"
            echo ""
            echo "  Other commands:"
            echo "    masonctl status    Check service health"
            echo "    masonctl logs -f   Follow container logs"
            echo "    masonctl login     Re-authenticate if session expires"
            echo ""
            return 0
        fi
        sleep 1
    done
    print_warning "Web server not responding yet - check logs with: masonctl logs"
}

# Stop the container
cmd_stop() {
    while [ $# -gt 0 ]; do
        case "$1" in --yes|-y) SKIP_CONFIRM=true; shift ;; *) shift ;; esac
    done
    check_docker

    if ! container_exists; then
        print_warning "Container '$CONTAINER_NAME' does not exist"
        return 0
    fi

    if ! container_running; then
        print_warning "Container '$CONTAINER_NAME' is not running"
        return 0
    fi

    confirm_action "This will stop all running services and agent sessions." || return 0

    print_status "Stopping container '$CONTAINER_NAME'..."
    # Give entrypoint 30s to gracefully stop mason server + PostgreSQL
    docker stop --timeout 30 "$CONTAINER_NAME"
    print_status "Container stopped"
}

# Restart the container
cmd_restart() {
    while [ $# -gt 0 ]; do
        case "$1" in --yes|-y) SKIP_CONFIRM=true; shift ;; *) shift ;; esac
    done
    check_docker
    confirm_action "This will restart the container, interrupting all running services and agent sessions." || return 0
    # Skip nested confirm in cmd_stop since we already confirmed
    SKIP_CONFIRM=true cmd_stop
    cmd_start
}

# Show container status
cmd_status() {
    check_docker

    if ! container_exists; then
        echo "Container: not created"
        return 0
    fi

    local state
    state=$(docker container inspect -f '{{.State.Status}}' "$CONTAINER_NAME" 2>/dev/null)

    echo "Container: $CONTAINER_NAME"
    echo "State:     $state"

    if container_running; then
        local started
        started=$(docker container inspect -f '{{.State.StartedAt}}' "$CONTAINER_NAME" 2>/dev/null)
        echo "Started:   $started"
        echo ""
        echo "Ports:"
        echo "  Web UI:      https://localhost:${PORT_WEB}"
        echo "  Mattermost:  https://localhost:${PORT_MM}"
        echo "  Forgejo:     https://localhost:${PORT_FORGEJO}"
        echo ""
        echo "Services:"
        # Check service health via API
        if curl -skf "https://localhost:${PORT_WEB}/api/status/json" > /dev/null 2>&1 || \
           curl -sf "http://localhost:${PORT_WEB}/api/status/json" > /dev/null 2>&1; then
            (curl -skf "https://localhost:${PORT_WEB}/api/status/json" 2>/dev/null || \
             curl -sf "http://localhost:${PORT_WEB}/api/status/json" 2>/dev/null) | \
                python3 -c "import sys,json; d=json.load(sys.stdin); [print(f'  {s[\"name\"]}: {s[\"state\"]}') for s in d.get('services',[])]" 2>/dev/null || \
                echo "  (API available but could not parse response)"
        else
            echo "  (API not responding)"
        fi
    fi
}

# View container logs
cmd_logs() {
    check_docker

    if ! container_exists; then
        print_error "Container '$CONTAINER_NAME' does not exist"
        exit 1
    fi

    local follow=""
    local tail="100"

    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--follow) follow="-f"; shift ;;
            -n|--tail) tail="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    docker logs $follow --tail "$tail" "$CONTAINER_NAME"
}

# Execute command inside container
cmd_exec() {
    check_docker

    if ! container_running; then
        print_error "Container '$CONTAINER_NAME' is not running"
        exit 1
    fi

    if [ $# -eq 0 ]; then
        # Interactive shell
        docker exec -it "$CONTAINER_NAME" /bin/bash
    else
        # Run specific command
        docker exec "$CONTAINER_NAME" "$@"
    fi
}

# Pull the latest image
cmd_pull() {
    check_docker
    print_status "Pulling image '$IMAGE_NAME'..."
    docker pull "$IMAGE_NAME"
    print_status "Pull complete"
}

# Update: pull latest image and restart
cmd_update() {
    while [ $# -gt 0 ]; do
        case "$1" in --yes|-y) SKIP_CONFIRM=true; shift ;; *) shift ;; esac
    done
    check_docker
    confirm_action "This will pull the latest image and restart the container." || return 0
    print_status "Updating MASON..."
    SKIP_CONFIRM=true cmd_pull
    if container_running; then
        SKIP_CONFIRM=true cmd_restart
    else
        print_status "Container not running. Start with: masonctl start"
    fi
}

# Remove container (and optionally data)
cmd_rm() {
    check_docker

    local remove_data=false
    while [ $# -gt 0 ]; do
        case "$1" in
            --data|-d) remove_data=true; shift ;;
            --yes|-y) SKIP_CONFIRM=true; shift ;;
            *) shift ;;
        esac
    done

    if [ "$remove_data" = true ]; then
        confirm_action "This will remove the container AND delete all data (agents, chat history, repos). This cannot be undone." || return 0
    else
        confirm_action "This will remove the container. Data volume will be preserved." || return 0
    fi

    if container_running; then
        print_status "Stopping container..."
        docker stop --timeout 30 "$CONTAINER_NAME"
    fi

    if container_exists; then
        print_status "Removing container..."
        docker rm "$CONTAINER_NAME"
    fi

    if [ "$remove_data" = true ]; then
        print_warning "Removing data volume '$DATA_VOLUME'..."
        docker volume rm "$DATA_VOLUME" 2>/dev/null || true

        # Check for orphaned trusted certificates in the system trust store
        if remove_trusted_certs "prompt" 2>/dev/null; then
            true  # certs removed (or user declined)
        fi

        # Remove local security directory (~/.mason)
        if [ -d "$MASON_DIR" ]; then
            print_warning "Removing security directory '$MASON_DIR'..."
            rm -rf "$MASON_DIR"
        fi
    fi

    print_status "Cleanup complete"
}

# Toggle daemon debug logging
cmd_debug() {
    check_docker

    if ! container_running; then
        print_error "Container '$CONTAINER_NAME' is not running"
        exit 1
    fi

    local action="${1:-on}"

    case "$action" in
        on|off)
            print_status "Toggling daemon debug logging..."
            docker exec "$CONTAINER_NAME" bash -c '
                DAEMON_PID=$(pgrep -x mason-daemon 2>/dev/null | head -1 || true)
                if [ -z "$DAEMON_PID" ]; then
                    echo "ERROR: mason-daemon is not running. Complete the setup wizard first."
                    exit 1
                fi
                # SIGUSR1 toggles between INFO and DEBUG without restart
                kill -USR1 "$DAEMON_PID"
                echo "Sent SIGUSR1 to mason-daemon (PID: $DAEMON_PID)"
            '
            print_status "Log level toggled. View with: masonctl logs -f 2>&1 | grep detectCombined"
            ;;
        *)
            echo "Usage: masonctl debug [on|off]"
            exit 1
            ;;
    esac
}

# Verify integrity of MASON files in the container
cmd_verify() {
    check_docker

    if ! container_running; then
        print_error "Container '$CONTAINER_NAME' is not running"
        exit 1
    fi

    docker exec "$CONTAINER_NAME" mason-verify "$@"
}

# Add MASON's self-signed certificate to the system trust store
cmd_trust_cert() {
    local cert_path="${MASON_DIR}/tls/mason.crt"

    if [ ! -f "$cert_path" ]; then
        print_error "No certificate found at $cert_path"
        echo ""
        echo "  Run 'masonctl start' first to generate the certificate."
        echo ""
        exit 1
    fi

    echo ""
    echo -e "  ${GREEN}Trust MASON Certificate${NC}"
    echo -e "  ──────────────────────────────────────────"
    echo ""
    echo "  This will add MASON's self-signed TLS certificate to your"
    echo "  system trust store so your browser no longer shows security"
    echo "  warnings when accessing MASON services."
    echo ""
    echo "  Certificate: $cert_path"
    echo ""
    echo "  What this does:"
    echo "    • Adds the certificate to your OS keychain/trust store"
    echo "    • Marks it as trusted for SSL/TLS connections"
    echo "    • Only affects connections to localhost (MASON services)"
    echo "    • If a previous MASON certificate exists, it will be"
    echo "      removed and replaced with the current one"
    echo ""
    echo "  A system dialog box will appear on your screen asking you to"
    echo "  authorize the keychain change. Enter your password and click"
    echo "  'Update Settings' (or 'Allow') to proceed."
    echo ""

    confirm_action "Add MASON's certificate to your system trust store?" || return 0

    if [ "$(uname)" = "Darwin" ]; then
        # Remove any existing MASON certs first (add-trusted-cert creates duplicates)
        remove_trusted_certs "silent" 2>/dev/null || true

        # Add to system keychain, scoped to SSL only
        print_status "Adding certificate to macOS Keychain..."
        if sudo security add-trusted-cert -d -r trustRoot -p ssl \
            -k /Library/Keychains/System.keychain "$cert_path"; then
            echo ""
            print_status "Certificate trusted successfully!"
            echo ""
            echo "  You may need to restart your browser for the change to take effect."
            echo ""
        else
            print_error "Failed to add certificate. Check your password and try again."
            exit 1
        fi
    elif [ -d "/usr/local/share/ca-certificates" ]; then
        # Debian/Ubuntu
        print_status "Adding certificate to system trust store..."
        if sudo cp "$cert_path" /usr/local/share/ca-certificates/mason.crt && \
           sudo update-ca-certificates; then
            echo ""
            print_status "Certificate trusted successfully!"
            echo ""
            echo "  You may need to restart your browser for the change to take effect."
            echo ""
        else
            print_error "Failed to update certificates."
            exit 1
        fi
    elif [ -d "/etc/pki/ca-trust/source/anchors" ]; then
        # RHEL/Fedora
        print_status "Adding certificate to system trust store..."
        if sudo cp "$cert_path" /etc/pki/ca-trust/source/anchors/mason.crt && \
           sudo update-ca-trust; then
            echo ""
            print_status "Certificate trusted successfully!"
            echo ""
            echo "  You may need to restart your browser for the change to take effect."
            echo ""
        else
            print_error "Failed to update certificates."
            exit 1
        fi
    else
        print_error "Could not detect your OS trust store."
        echo ""
        echo "  You can manually trust the certificate at:"
        echo "    $cert_path"
        echo ""
        exit 1
    fi
}

# Remove all MASON certificates from the system trust store.
# Args: $1 = "prompt" (ask before removing) or "silent" (remove without asking, for rm --data)
# Returns 0 if certs were found and removed, 1 if none found.
remove_trusted_certs() {
    local mode="${1:-prompt}"

    if [ "$(uname)" = "Darwin" ]; then
        local existing_hashes
        existing_hashes=$(security find-certificate -a -c "MASON Local" -Z \
            /Library/Keychains/System.keychain 2>/dev/null | grep "SHA-256" | sed 's/.*: //')
        if [ -z "$existing_hashes" ]; then
            return 1
        fi

        local cert_count
        cert_count=$(echo "$existing_hashes" | wc -l | tr -d ' ')

        if [ "$mode" = "prompt" ]; then
            echo ""
            print_status "Found $cert_count MASON certificate(s) in macOS Keychain."
            echo ""
            echo "  A system dialog box will appear asking you to authorize"
            echo "  the keychain change. Enter your password and click"
            echo "  'Update Settings' (or 'Allow') to proceed."
            echo ""
            confirm_action "Remove all $cert_count MASON certificate(s) from keychain?" || return 0
        fi

        print_status "Removing $cert_count MASON certificate(s) from macOS Keychain..."
        for hash in $existing_hashes; do
            sudo security delete-certificate -Z "$hash" -t \
                /Library/Keychains/System.keychain 2>/dev/null || true
        done
        print_status "Certificate(s) removed."
        return 0
    elif [ -f "/usr/local/share/ca-certificates/mason.crt" ]; then
        if [ "$mode" = "prompt" ]; then
            echo ""
            print_status "Found MASON certificate in system trust store."
            confirm_action "Remove MASON certificate from trust store?" || return 0
        fi
        print_status "Removing certificate from system trust store..."
        sudo rm -f /usr/local/share/ca-certificates/mason.crt
        sudo update-ca-certificates
        print_status "Certificate removed."
        return 0
    elif [ -f "/etc/pki/ca-trust/source/anchors/mason.crt" ]; then
        if [ "$mode" = "prompt" ]; then
            echo ""
            print_status "Found MASON certificate in system trust store."
            confirm_action "Remove MASON certificate from trust store?" || return 0
        fi
        print_status "Removing certificate from system trust store..."
        sudo rm -f /etc/pki/ca-trust/source/anchors/mason.crt
        sudo update-ca-trust
        print_status "Certificate removed."
        return 0
    else
        return 1
    fi
}

# Remove MASON's certificate from the system trust store
cmd_untrust_cert() {
    echo ""
    echo -e "  ${GREEN}Remove MASON Certificate${NC}"
    echo -e "  ──────────────────────────────────────────"
    echo ""
    echo "  Checking for MASON certificates in your system trust store..."

    if ! remove_trusted_certs "prompt"; then
        print_warning "No MASON certificates found in trust store."
    fi
    echo ""
}

# Show help
cmd_help() {
    cat <<EOF
masonctl - MASON container management tool

Usage: masonctl <command> [options]

Commands:
  start                 Start the MASON container
  stop                  Stop the MASON container
  restart               Restart the MASON container
  pull                  Pull the latest image from registry
  update                Pull latest image and restart
  status                Show container and service status
  logs [-f] [-n N]      View container logs (-f to follow, -n for tail lines)
  exec [cmd...]         Execute command in container (or shell if no cmd)
  token                 Print the current API token
  login                 Open browser to login page (with token instructions)
  debug                 Toggle daemon debug logging (SIGUSR1, no restart)
  trust-cert            Add MASON's TLS cert to system trust store
  untrust-cert          Remove MASON's TLS cert from system trust store
  verify [flags...]     Verify integrity of MASON files in the container
  rm [--data]           Remove container (--data also removes volume)
  help                  Show this help message

Global Flags:
  --yes, -y             Skip confirmation prompts (for scripting)

Environment Variables:
  MASON_CONTAINER_NAME  Container name (default: mason)
  MASON_IMAGE_NAME      Image name (default: masonteams/mason-teams:stable)
  MASON_DATA_VOLUME     Data volume name (default: mason-data)
  MASON_DIR             Security directory (default: ~/.mason)
  MASON_PORT_WEB        Web UI port (default: 8080)
  MASON_PORT_MM         Mattermost port (default: 8065)
  MASON_PORT_FORGEJO    Forgejo port (default: 3000)

Examples:
  masonctl start                  # Start container
  masonctl logs -f                # Follow logs
  masonctl exec                   # Open shell in container
  masonctl exec mason status      # Run mason CLI inside container
  masonctl pull                   # Pull latest image from registry
  masonctl update                 # Pull latest and restart
  masonctl token                  # Print the API token
  masonctl login                  # Open login page in browser
  masonctl debug                  # Toggle daemon debug logging
  masonctl trust-cert             # Trust MASON's self-signed certificate
  masonctl untrust-cert           # Remove MASON's certificate from trust store
  masonctl verify                 # Verify integrity of MASON files
  masonctl verify --remote        # Verify with remote checks
  masonctl rm --data              # Remove container and all data

EOF
}

# Parse global flags
while [ $# -gt 0 ]; do
    case "$1" in
        --yes|-y) SKIP_CONFIRM=true; shift ;;
        *) break ;;
    esac
done

# Main command dispatch
case "${1:-help}" in
    start)   shift; cmd_start "$@" ;;
    stop)    shift; cmd_stop "$@" ;;
    restart) shift; cmd_restart "$@" ;;
    pull)    shift; cmd_pull "$@" ;;
    update)  shift; cmd_update "$@" ;;
    status)  shift; cmd_status "$@" ;;
    logs)    shift; cmd_logs "$@" ;;
    exec)    shift; cmd_exec "$@" ;;
    token)   shift; cmd_token "$@" ;;
    login)   shift; cmd_login "$@" ;;
    debug)   shift; cmd_debug "$@" ;;
    trust-cert)   shift; cmd_trust_cert "$@" ;;
    untrust-cert) shift; cmd_untrust_cert "$@" ;;
    verify)  shift; cmd_verify "$@" ;;
    rm)      shift; cmd_rm "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        print_error "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
