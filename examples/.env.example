# MASON Configuration
# Copy this file to .env and customize as needed.
# All values shown are defaults — only set what you want to change.

# Container settings
MASON_CONTAINER_NAME=mason
MASON_IMAGE_NAME=ghcr.io/mason-teams/mason-teams:latest
MASON_DATA_VOLUME=mason-data

# Port mapping (host:container)
MASON_PORT_WEB=8080        # Web UI
MASON_PORT_MM=8065         # Mattermost
MASON_PORT_FORGEJO=3000    # Forgejo
MASON_PORT_TTYD=7681       # Terminal
MASON_PORT_QDRANT=6333     # Qdrant vector DB
MASON_PORT_DAEMON=9090     # Daemon metrics/SSE

# Resource limits
MASON_MEMORY=16g           # Container memory limit
MASON_CPUS=8               # Container CPU limit
MASON_SHM_SIZE=2g          # Shared memory (for Chromium/browser agents)
